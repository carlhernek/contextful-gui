<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    PyInstaller extracts libpython and other dylibs at runtime; those embedded
    libraries are signed with a different (ad-hoc) identity than the app's
    stable signing identity. Without disabling library validation, macOS
    refuses to load them ("different Team IDs") and the sidecar exits instantly.
  -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
